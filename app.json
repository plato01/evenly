{
  "expo": {
    "name": "Evenly",
    "slug": "Evenly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/LOGO/dollar origami real.png",
    "scheme": "evenly",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow $(PRODUCT_NAME) to use speech recognition.",
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to use the microphone.",
        "NSContactsUsageDescription": "Allow $(PRODUCT_NAME) to access your contacts to find friends.",
        "NSCameraUsageDescription": "Allow $(PRODUCT_NAME) to use the camera to scan receipts."
      }
    },
    "android": {
      "icon": "./assets/LOGO/dollar origami real.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/LOGO/dollar origami real.png",
        "backgroundColor": "#6C3CE7"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CONTACTS",
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ],
      "package": "com.evenly.app",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-system-ui",
        {
          "backgroundColor": "#0B0D12"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/LOGO/dollar origami real.png",
          "imageWidth": 1,
          "resizeMode": "contain",
          "backgroundColor": "#12101A",
          "dark": {
            "backgroundColor": "#12101A"
          }
        }
      ],
      "expo-secure-store",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./assets/LOGO/black origami new.png",
          "color": "#F43F5E"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-speech-recognition",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Evenly to use the camera to scan receipts."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow Evenly to access your contacts to find friends."
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-firebase/messaging",
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
